# ── LLM Provider ──
LLM_DEFAULT_MODEL=deepseek-chat
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1

# ── GitHub / Gitee ──
GITHUB_TOKEN=ghp_xxxxx
GITEE_TOKEN=xxxxx

# ── Web Search ──
SERPER_API_KEY=xxxxx                     # serper.dev — Google Search API, 2500 free
TAVILY_API_KEY=tvly-xxxxx                 # tavily.com — alternative search API

# ── Web Scraping ──
FIRECRAWL_API_KEY=fc-xxxxx                # firecrawl.dev — 500 pages/month free

# ── News ──
NEWSAPI_KEY=xxxxx                         # newsapi.org — 100 requests/day free

# ── Product Hunt ──
PRODUCTHUNT_API_KEY=xxxxx
PRODUCTHUNT_API_SECRET=xxxxx

# ── LLM Cache ──
# LLM 语义缓存 TTL（秒），默认 30 天
LLM_CACHE_TTL_SECONDS=2592000

# ── Tool Cache（新增） ──
# 工具调用缓存模式：
#   auto        — 命中返回缓存，未命中调 API 并写回（默认）
#   force_cache — 只读缓存，未命中返回 error，用于 demo 录制
#   bypass      — 跳过缓存直接调 API，用于预灌缓存
TOOL_CACHE_MODE=auto